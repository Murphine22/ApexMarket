# --- ApexMarket Backend Environment ---

# Server
NODE_ENV=development
PORT=5000

# CORS — the frontend origin allowed to call the API
CLIENT_URL=http://localhost:3000

# Database (MongoDB Atlas or local). Example local: mongodb://127.0.0.1:27017/apexmarket
MONGO_URI=mongodb://127.0.0.1:27017/apexmarket

# JWT secrets — generate strong random values in production!
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
