# --- ApexMarket Frontend Environment ---

# Toggle the data source.
#   false (default) -> standalone DEMO mode, no backend needed. localhost:3000 just works.
#   true            -> talk to the real Express/Mongo backend.
VITE_USE_API=false

# Base URL for the backend API when VITE_USE_API=true.
# Leave as /api to use the Vite dev proxy (recommended for local dev).
VITE_API_URL=/api

# Where the Vite dev-server proxy forwards /api requests during `npm run dev`.
VITE_API_TARGET=http://localhost:5000
